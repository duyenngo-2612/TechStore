@model IEnumerable<TechStore.Models.Product>
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted fs-5">Chưa có sản phẩm nào trong mục này.</p>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 product-card p-3 border-0 shadow-sm">
                    <div class="text-center mb-3 position-relative">
                        <span class="badge bg-danger position-absolute top-0 end-0 rounded-pill">-10%</span>

                        @{
                            // LOGIC KIỂM TRA ẢNH MÀ BẠN CẦN
                            string imagePath = "/images/default.jpg"; // Mặc định ban đầu

                            if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                if (item.ImageUrl.StartsWith("http"))
                                {
                                    imagePath = item.ImageUrl; // Nếu là link web thì lấy luôn
                                }
                                else
                                {
                                    // Lọc lấy tên file nguyên bản
                                    string fileName = item.ImageUrl.Replace("/images/", "").Replace("~/", "").Replace("/", "");
                                    string physicalPath = System.IO.Path.Combine(Env.WebRootPath, "images", fileName);

                                    // KIỂM TRA XEM FILE CÓ TRÊN Ổ CỨNG KHÔNG
                                    if (System.IO.File.Exists(physicalPath))
                                    {
                                        imagePath = "/images/" + fileName;
                                    }
                                }
                            }
                        }

                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">
                            <img src="@imagePath"
                                 class="img-fluid"
                                 style="height: 180px; width: 100%; object-fit: contain;"
                                 onerror="this.src='/images/default.jpg'">
                        </a>
                    </div>

                    <div class="card-body p-0">
                        <p class="product-category mb-1 text-muted small">Chính hãng</p>
                        <h6 class="product-name fw-bold mb-2" style="height: 40px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">
                                @item.ProductName
                            </a>
                        </h6>
                        <p class="text-danger fw-bold fs-5 mb-0">@item.Price.ToString("#,##0") ₫</p>
                    </div>

                    <div class="mt-3">
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="w-100 add-to-cart-btn">
                                <i class="bi bi-cart-plus-fill me-2"></i> THÊM VÀO GIỎ
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>