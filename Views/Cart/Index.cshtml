@model IEnumerable<TechStore.Models.Cart>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart-check text-danger"></i> GIỎ HÀNG CỦA BẠN</h2>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">Xử lý</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr id="row-@item.ProductId">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "/images/default.jpg" : item.Product.ImageUrl)"
                                                 style="width: 60px; height: 60px; object-fit: contain;" class="me-3">
                                            <span class="fw-bold text-dark">@item.Product.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="input-group input-group-sm justify-content-center">
                                            <button class="btn btn-outline-secondary btn-update" data-id="@item.ProductId" data-change="-1">-</button>
                                            <span class="input-group-text bg-white px-3 fw-bold" id="qty-@item.ProductId">@item.Quantity</span>
                                            <button class="btn btn-outline-secondary btn-update" data-id="@item.ProductId" data-change="1">+</button>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @item.Product.Price.ToString("#,##0") ₫
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger btn-remove" data-id="@item.ProductId">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 p-4 rounded-3 bg-white">
                <h5 class="fw-bold border-bottom pb-2">TỔNG ĐƠN HÀNG</h5>
                <div class="d-flex justify-content-between my-3">
                    <span>Tạm tính:</span>
                    <span class="fw-bold fs-5 text-danger">@Model.Sum(x => x.Quantity * x.Product.Price).ToString("#,##0") ₫</span>
                </div>
                <button class="btn btn-danger w-100 py-3 fw-bold rounded-pill">TIẾN HÀNH THANH TOÁN</button>
                <a href="/" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Xử lý Tăng/Giảm số lượng
            $('.btn-update').click(function () {
                var productId = $(this).data('id');
                var change = $(this).data('change');

                $.post('/Cart/UpdateQuantity', { productId: productId, change: change }, function (response) {
                    if (response.success) {
                        location.reload(); // Cách nhanh nhất để cập nhật tổng tiền
                        $('#cart-count-badge').text(response.newCount);
                    }
                });
            });

            // Xử lý Xóa sản phẩm
            $('.btn-remove').click(function () {
                if(confirm("Bạn muốn xóa sản phẩm này khỏi giỏ hàng?")) {
                    var productId = $(this).data('id');
                    $.post('/Cart/Remove', { productId: productId }, function (response) {
                        if (response.success) {
                            $('#row-' + productId).fadeOut();
                            location.reload();
                        }
                    });
                }
            });
        });
    </script>
}