@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow-sm border-0 rounded-lg p-5">
                <div class="mb-4">
                    <i class="fas fa-check-circle text-success" style="font-size: 6rem;"></i>
                </div>

                <h2 class="text-success font-weight-bold">Cảm ơn bạn đã đặt hàng!</h2>

                @if (TempData["SuccessMessage"] != null)
                {
                    <p class="lead text-muted mt-3">@TempData["SuccessMessage"]</p>
                }
                else
                {
                    <p class="lead text-muted mt-3">Đơn hàng của bạn đã được ghi nhận thành công.</p>
                }

                <p class="text-muted">Chúng tôi sẽ sớm liên hệ với bạn để xác nhận đơn hàng và tiến hành giao hàng trong thời gian sớm nhất.</p>

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary mx-2">
                        <i class="fas fa-home"></i> Về trang chủ
                    </a>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary mx-2">
                        Tiếp tục mua sắm <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>