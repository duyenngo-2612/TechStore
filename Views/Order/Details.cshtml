@model TechStore.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">CHI TIẾT ĐƠN HÀNG #@Model.OrderId</h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Sản phẩm đã mua</h5>
                    <table class="table">
                        <tbody>
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <tr>
                                    <td style="width: 80px;">
                                        <img src="@(string.IsNullOrEmpty(detail.Product.ImageUrl) ? "/images/default.jpg" : "/images/" + detail.Product.ImageUrl)" class="img-fluid rounded" />
                                    </td>
                                    <td>
                                        <div class="fw-bold">@detail.Product.ProductName</div>
                                        <small class="text-muted">Số lượng: @detail.Quantity</small>
                                    </td>
                                    <td class="text-end fw-bold">@((detail.UnitPrice * detail.Quantity).ToString("#,##0")) đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Thông tin đơn hàng</h5>
                    <p class="mb-1"><strong>Người nhận:</strong> @Context.Session.GetString("UserName")</p>
                    <p class="mb-1"><strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                    <p class="mb-1"><strong>Thanh toán:</strong> @Model.PaymentMethod</p>
                    <hr>
                    <div class="d-flex justify-content-between fs-5 fw-bold text-danger">
                        <span>TỔNG TIỀN:</span>
                        <span>@Model.TotalAmount.ToString("#,##0") đ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>