@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Giữ nguyên Style của bạn */
        body {
            font-family: 'Roboto', sans-serif;
            background-color: #f8f9fa;
        }

        .navbar-main {
            background-color: #15161D;
            border-bottom: 3px solid #D10024;
        }

        .nav-link {
            color: #fff !important;
            text-transform: uppercase;
            font-weight: 500;
        }

        .cart-badge {
            background-color: #D10024;
            color: white;
            border-radius: 50%;
            padding: 2px 7px;
            font-size: 12px;
            position: absolute;
            top: 0;
            right: 0;
        }

        .search-bar {
            border-radius: 40px 0 0 40px;
            border: 1px solid #E4E7ED;
            padding: 10px 20px;
        }

        .search-btn {
            border-radius: 0 40px 40px 0;
            background-color: #D10024;
            color: #fff;
            border: none;
            padding: 0 25px;
            font-weight: 700;
        }

        .footer-admin-link {
            opacity: 0.3;
            transition: 0.3s;
            text-decoration: none;
            color: #fff;
            font-size: 12px;
        }

            .footer-admin-link:hover {
                opacity: 1;
                color: #D10024;
            }

        /* Chỉnh lại dropdown cho đẹp */
        .dropdown-item i {
            margin-right: 8px;
            color: #888;
        }

        .dropdown-item:hover i {
            color: #D10024;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-main py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-white fs-3" asp-controller="Home" asp-action="Index">
                    TECH<span style="color: #D10024;">STORE</span>
                </a>

                <div class="d-flex mx-auto w-50 d-none d-lg-flex">
                    <input id="txtSearch" class="form-control search-bar" type="text" placeholder="Gõ tên sản phẩm để tìm kiếm...">
                    <button class="search-btn" type="button">TÌM KIẾM</button>
                </div>

                <div class="d-flex align-items-center">
                    @{
                        var cartCount = HttpContextAccessor.HttpContext.Session.GetString("CartCount") ?? "0";
                        var userName = HttpContextAccessor.HttpContext.Session.GetString("UserName");
                    }
                    <a class="nav-link text-white position-relative me-3" asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart3 fs-4"></i>
                        <span id="cart-count-badge" class="cart-badge">@cartCount</span>
                    </a>

                    @if (userName != null)
                    {
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle text-white fw-bold" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> @userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">
                                        <i class="bi bi-person-vcard"></i> Thông tin cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Order" asp-action="Index">
                                        <i class="bi bi-bag-check"></i> Đơn hàng của tôi
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 - TechStore</span>
            <a asp-area="Admin" asp-controller="Account" asp-action="Login" class="footer-admin-link">Admin Area</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#txtSearch").on("keyup", function () {
                var value = $(this).val();
                var categoryId = $(".btn-category.active").data("id") || 0;

                $.get('/Home/GetProductsByCategory', { categoryId: categoryId, search: value }, function (data) {
                    $('#product-list-container').html(data);
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>