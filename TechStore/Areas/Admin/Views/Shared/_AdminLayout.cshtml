@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #f4f7f6;
        }

        /* Cố định Sidebar bên trái */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: #fff;
            border-right: 1px solid #ddd;
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        /* Đẩy nội dung sang phải */
        .main-content {
            margin-left: 260px;
            padding: 30px;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .nav-link {
            color: #555;
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 15px;
            transition: all 0.2s;
        }

            .nav-link:hover {
                background: #f8f9fa;
                color: #0d6efd;
            }

            /* Logic bôi xanh menu đang chọn */
            .nav-link.active {
                background: #e7f1ff !important;
                color: #0d6efd !important;
                font-weight: bold;
            }

        .logout-section {
            margin-top: auto;
            padding: 20px;
            border-top: 1px solid #eee;
        }

        .admin-profile {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            padding-left: 10px;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar shadow-sm">
            <div class="p-4 fs-4 fw-bold logo-admin">
            <span class="text-black px-2  py-1 rounded">TECH</span><span class="text-danger">STORE</span>
            </div>

            <nav class="nav flex-column">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid-1x2 me-2"></i> Tổng quan
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")"
                   asp-area="Admin" asp-controller="Product" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i> Sản phẩm
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" ? "active" : "")"
                   asp-area="Admin" asp-controller="Order" asp-action="Index">
                    <i class="bi bi-bag-check me-2"></i> Quản lý Đơn hàng
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Review" ? "active" : "")"
                   asp-area="Admin" asp-controller="Review" asp-action="Index">
                    <i class="bi bi-star me-2"></i> Đánh giá
                </a>
            </nav>

            <div class="logout-section">
                <div class="admin-profile">
                    <i class="bi bi-person-circle fs-3 me-2 text-secondary"></i>
                    <div class="small overflow-hidden">
                        <div class="fw-bold text-truncate">@Context.Session.GetString("AdminName")</div>
                        <div class="text-muted text-truncate" style="font-size: 11px;">@Context.Session.GetString("AdminEmail")</div>
                    </div>
                </div>
                <a asp-area="Admin" asp-controller="Account" asp-action="Logout"
                   class="btn btn-danger w-100 fw-bold shadow-sm"
                   onclick="return confirm('Bạn có chắc chắn muốn đăng xuất?')">
                    <i class="bi bi-box-arrow-right me-2"></i> ĐĂNG XUẤT
                </a>
            </div>
        </div>

        <div class="main-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>