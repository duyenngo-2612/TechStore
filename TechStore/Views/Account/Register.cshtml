@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h4>ĐĂNG KÝ THÀNH VIÊN</h4>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Register" method="post">
                    <div class="form-group mb-3">
                        <label class="fw-bold">Họ và Tên</label>
                        <input type="text" name="fullName" class="form-control" placeholder="Nhập họ tên của bạn" required />
                    </div>
                    <div class="form-group mb-3">
                        <label class="fw-bold">Địa chỉ Email (Gmail)</label>
                        <input type="email" name="email" class="form-control" placeholder="vidu@gmail.com" required />
                    </div>
                    <div class="form-group mb-4">
                        <label class="fw-bold">Mật khẩu</label>
                        <input type="password" name="password" class="form-control" placeholder="Tạo mật khẩu" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">ĐĂNG KÝ & NHẬN MÃ OTP</button>
                </form>
            </div>
        </div>
    </div>
</div>