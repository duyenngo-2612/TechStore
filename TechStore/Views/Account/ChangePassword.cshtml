@model TechStore.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    var userName = Context.Session.GetString("UserName") ?? "Khách hàng";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="bg-dark p-4 text-center">
                    <div class="rounded-circle bg-danger d-inline-flex align-items-center justify-content-center text-white mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-shield-lock fs-2"></i>
                    </div>
                    <h6 class="text-white mb-0">@userName</h6>
                    <p class="text-white-50 small">Bảo mật tài khoản</p>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Profile" class="list-group-item list-group-item-action"><i class="bi bi-person-vcard me-2"></i> Thông tin tài khoản</a>
                    <a href="#" class="list-group-item list-group-item-action active"><i class="bi bi-key me-2"></i> Đổi mật khẩu</a>
                    <a asp-controller="Order" asp-action="Index" class="list-group-item list-group-item-action"><i class="bi bi-box-seam me-2"></i> Đơn hàng của tôi</a>
                    <a asp-action="Logout" class="list-group-item list-group-item-action text-danger"><i class="bi bi-power me-2"></i> Đăng xuất</a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card border-0 shadow-sm rounded-3 p-4">
                <h4 class="fw-bold mb-4 border-bottom pb-3 text-uppercase"><i class="bi bi-key-fill text-danger"></i> Thay đổi mật khẩu</h4>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error</div>
                }

                <form asp-action="ChangePassword" method="post">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label small fw-bold">Mật khẩu hiện tại</label>
                            <input type="password" asp-for="OldPassword" class="form-control" placeholder="Nhập mật khẩu đang sử dụng">
                            <span asp-validation-for="OldPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-md-8 mt-4">
                            <label class="form-label small fw-bold">Mật khẩu mới</label>
                            <input type="password" asp-for="NewPassword" class="form-control" placeholder="Tối thiểu 6 ký tự">
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-md-8">
                            <label class="form-label small fw-bold">Xác nhận mật khẩu mới</label>
                            <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới">
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-danger px-5 fw-bold shadow-sm rounded-pill">
                            <i class="bi bi-check2-circle me-1"></i> XÁC NHẬN ĐỔI MẬT KHẨU
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #D10024;
        box-shadow: 0 0 0 0.25rem rgba(209, 0, 36, 0.1);
    }

    .list-group-item.active {
        background-color: #D10024;
        border-color: #D10024;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}