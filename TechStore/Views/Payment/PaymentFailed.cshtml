@{
    ViewData["Title"] = "Thanh toán thất bại";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm border-0 rounded-lg p-5">
                <div class="mb-4">
                    <i class="fas fa-times-circle text-danger" style="font-size: 6rem;"></i>
                </div>

                <h2 class="text-danger font-weight-bold">Thanh toán không thành công!</h2>

                @if (TempData["ErrorMessage"] != null)
                {
                    <p class="lead text-dark mt-3">@TempData["ErrorMessage"]</p>
                }
                else
                {
                    <p class="lead text-dark mt-3">Đã có lỗi xảy ra trong quá trình giao dịch hoặc bạn đã hủy thanh toán.</p>
                }

                <p class="text-muted">Đơn hàng của bạn chưa được thanh toán. Vui lòng thử lại hoặc chọn phương thức thanh toán khác.</p>

                <div class="mt-4">
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-primary px-4 py-2">
                        <i class="fas fa-shopping-cart"></i> Quay lại giỏ hàng
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>